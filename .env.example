NEXT_PUBLIC_SITE_URL=https://hcmgloans.com

# Cloudflare Turnstile (create an Invisible widget for the production domain).
# Both values must be configured together. Without them, the other anti-spam
# controls remain active but Turnstile verification is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
